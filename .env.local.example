# ---- Glasses connection ----------------------------------------------------
# Browser-facing base URL for the glasses REST API.
# Use "/g3" to route through the Next.js proxy (recommended; avoids CORS),
# or set it directly to http://<serial>.local if the glasses send CORS headers.
NEXT_PUBLIC_G3_BASE=/g3

# Server-side target for the Next.js rewrites proxy. This is your glasses
# recording unit's hostname (usually the serial number) on the lab network.
G3_HOST_INTERNAL=http://tg03b-080200000000.local

# Browser-facing direct URL of the glasses (no proxy). Optional. Used only by
# the reachability probe so it can compare proxy vs direct and tell you whether
# the CORS proxy is actually needed. Leave blank to skip the direct test.
NEXT_PUBLIC_G3_DIRECT=

# Browser-facing WebSocket URL of the glasses (sub-protocol "g3api"). The
# WebRTC adapter uses this to subscribe to the remote-ICE signal — HTTP
# subscriptions only deliver one message (docs §3.6). Leave blank to derive
# it from NEXT_PUBLIC_G3_DIRECT.
NEXT_PUBLIC_G3_WS=

# Which adapter to start with: "mock" (no hardware) or "webrtc" (real glasses).
NEXT_PUBLIC_ADAPTER=mock
